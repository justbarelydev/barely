{
	"name": "barely",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "UI build on native browser APIs",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "npm run build --workspaces",
		"build:data": "cd packages/data && npm run build && npm run build:esm",
		"watch:data": "cd packages/data && npm run watch",
		"dev": "npm run watch:data & npm run serve",
		"serve": "serve .",
		"watch": "browser-sync start --server --files '**/*' --no-notify",
		"lint": "eslint packages/"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"browser-sync": "^3.0.4",
		"esbuild": "^0.28.0",
		"eslint": "^10.4.1",
		"serve": "^14.2.6"
	}
}