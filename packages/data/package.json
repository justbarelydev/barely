{
	"name": "@justbarely/data",
	"version": "0.1.0",
	"description": "Placeholder data via HTML data attrs or JS imports",
	"license": "MIT",
	"files": [
		"dist"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/justbarelydev/barely.git"
	},
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"main": "./dist/index.esm.js",
	"exports": {
		".": "./dist/index.esm.js"
	},
	"scripts": {
		"build": "esbuild src/index.js --bundle --minify --format=iife --outfile=dist/index.js && esbuild src/index.js --bundle --minify --format=esm --outfile=dist/index.esm.js",
		"watch": "esbuild src/index.js --bundle --minify --format=iife --outfile=dist/index.js --watch",
		"serve": "serve .",
		"dev": "npm run watch & npm run serve",
		"prepublishOnly": "npm run build"
	}
}