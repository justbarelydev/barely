{
	"name": "@barely/data",
	"version": "0.1.0",
	"type": "module",
	"main": "./dist/index.esm.js",
	"exports": {
		".": "./dist/index.esm.js"
	},
	"scripts": {
		"build": "esbuild src/index.js --bundle --minify --format=iife --outfile=dist/index.js",
		"build:esm": "esbuild src/index.js --bundle --minify --format=esm --outfile=dist/index.esm.js",
		"watch": "esbuild src/index.js --bundle --minify --format=iife --outfile=dist/index.js --watch",
		"prepublishOnly": "npm run build && npm run build:esm"
	}
}